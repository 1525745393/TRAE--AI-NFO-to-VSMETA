# MANIFEST.in - 打包清单
# 指定在发布包中包含的文件

# 包含 README 和许可证
include README.md
include LICENSE
include CHANGELOG.md

# 包含配置文件
include requirements.txt
include pyproject.toml

# 包含文档目录
recursive-include docs *
recursive-include tests *

# 包含插件目录
recursive-include plugins *.py
recursive-include plugins *.json

# 排除测试缓存和临时文件
recursive-exclude tests __pycache__
recursive-exclude tests *.pyc
recursive-exclude tests .pytest_cache
recursive-exclude tests *.py.bak

# 排除插件缓存
recursive-exclude plugins __pycache__
recursive-exclude plugins *.pyc
recursive-exclude plugins configs *.json.bak

# 排除文档构建产物
recursive-exclude docs .build
recursive-exclude docs _build
